# ============================
# FlashShop Production Config
# ============================

# PostgreSQL
POSTGRES_USER=flashshop
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=flashshop

# Redis
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# JWT - at least 32 random characters
JWT_SECRET=CHANGE_ME_RANDOM_SECRET_AT_LEAST_32_CHARACTERS_LONG

# Admin Seed
ADMIN_EMAIL=admin@flashshop.dev
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# URLs
FRONTEND_URL=http://localhost
API_URL=http://localhost/api

# Ports
HTTP_PORT=80
